{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/lint_check.mjs",
            "timeout": 30,
            "statusMessage": "Running ESLint check..."
          }
        ]
      }
    ]
  }
}
